{
  "pluginAlias": "HomebridgeDummy",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",
  "schema": {
    "type": "object",
    "definitions": {
      "timer": {
        "type": "object",
        "properties": {
          "delay": {
            "type": "integer",
            "title": "${config.title.delay}", 
            "minimum": 1
          },
          "units": {
            "type": "string",
            "title": "${config.title.units}", 
            "enum": [ "SECONDS", "MINUTES", "HOURS"],
            "enumNames": ["${config.enumNames.seconds}", "${config.enumNames.minutes}", "${config.enumNames.hours}"]
          }
        }
      }
    },
    "properties": {
      "name": {
        "type": "string",
        "default": "Homebridge Dummy"
      },
      "accessories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "title": "${config.title.name}" ,         
              "required": true
            },
            "type": {
              "type": "string",
              "title": "${config.title.type}", 
              "enum": ["Switch"],
              "enumNames": ["${config.enumNames.switch}"],
              "required": true
            },
            "timer": { "$ref": "#/definitions/timer" },
            "defaultOn": {
              "type": "boolean",
              "title": "${config.title.defaultOn}"
            },
            "disableLogging": {
              "title": "${config.title.disableLogging}",
              "type": "boolean"
            }
          }
        }        
      }
    }
  },
    "layout": [
    {
      "type": "array",
      "key": "accessories",
      "title": "${config.title.accessories}",
      "items": [
        {
          "type": "fieldset",
          "expandable": true,
          "title": "${config.title.accessory}",
          "items": [
            {
              "type": "div",
              "displayFlex": true,
              "flex-direction": "row",
              "items": [
                {
                  "key": "accessories[].name",
                  "flex": "1 1 0"
                },
                {
                  "key": "accessories[].type",
                  "flex": "1 1 0"
                }
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.timer}",
              "expandable": true,
              "items": [
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].timer.delay",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].timer.units",
                      "flex": "1 1 0"
                    }
                  ]
                }
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.options}",
              "expandable": true,
              "condition": {
                "functionBody": "return ['Switch'].includes(model.accessories?.[arguments[1]]?.type);"
              },
              "items": [
                "accessories[].defaultOn"
              ]
            },            
            "accessories[].disableLogging"
          ]
        }
      ]
    }
  ]
}